{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cgasgarth/opencode-dynamic-subagents/blob/main/dynamicSubAgents.schema.json",
  "title": "OpenCode Dynamic Subagents",
  "type": "object",
  "additionalProperties": false,
  "required": ["agents"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "titlePrefix": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "variant": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number"
        },
        "top_p": {
          "type": "number"
        },
        "color": {
          "type": "string"
        },
        "hidden": {
          "type": "boolean"
        },
        "steps": {
          "type": "integer",
          "minimum": 1
        },
        "permission": {
          "type": "object"
        },
        "options": {
          "type": "object"
        },
        "allowedModels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowedVariants": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["description"],
        "properties": {
          "description": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "variant": {
            "type": "string",
            "minLength": 1
          },
          "temperature": {
            "type": "number"
          },
          "top_p": {
            "type": "number"
          },
          "color": {
            "type": "string"
          },
          "hidden": {
            "type": "boolean"
          },
          "steps": {
            "type": "integer",
            "minimum": 1
          },
          "permission": {
            "type": "object"
          },
          "options": {
            "type": "object"
          },
          "allowedModels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowedVariants": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
