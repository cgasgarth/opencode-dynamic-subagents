{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-dynamic-subagents",
  "version": "0.2.0",
  "description": "OpenCode plugin that adds policy-controlled dynamic subagents with runtime model and variant selection.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cgasgarth/opencode-dynamic-subagents.git"
  },
  "bugs": {
    "url": "https://github.com/cgasgarth/opencode-dynamic-subagents/issues"
  },
  "homepage": "https://github.com/cgasgarth/opencode-dynamic-subagents#readme",
  "private": false,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.11.0",
  "main": "./dist/entrypoint.js",
  "module": "./dist/entrypoint.js",
  "types": "./dist/entrypoint.d.ts",
  "exports": {
    ".": {
      "types": "./dist/entrypoint.d.ts",
      "default": "./dist/entrypoint.js"
    }
  },
  "files": [
    "dist",
    "dynamicSubAgents.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "check": "npm run lint && npm run typecheck && npm run test",
    "clean": "rm -rf dist",
    "lint": "eslint . --max-warnings=0",
    "test": "node --import tsx --test test/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.27",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@opencode-ai/sdk": "^1.2.27",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
